# Maintainer: Saeed Hany <saeed@saeeedhany.github.io>
pkgname=btorrent
pkgver=1.0.2
pkgrel=1
pkgdesc="Concurrent BitTorrent client with DHT, magnet links, seeding, and PEX"
arch=('linux_amd64' 'linux_aarch64')
url="https://alsullam.github.io/btorrent"
license=('MIT')
depends=('curl')
makedepends=('pkg-config')
source=("$pkgname-$pkgver.tar.gz::https://github.com/alsullam/Btorrent/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')  # Replace with: sha256sum btorrent-1.0.2.tar.gz

build() {
    cd "$pkgname-$pkgver"
    make VERSION="$pkgver" all
}

check() {
    cd "$pkgname-$pkgver"
    make test
}

package() {
    cd "$pkgname-$pkgver"
    make install \
        DESTDIR="$pkgdir" \
        PREFIX=/usr \
        VERSION="$pkgver"
    install -Dm644 LICENSE     "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 README.md   "$pkgdir/usr/share/doc/$pkgname/README.md"
    install -Dm644 CHANGES.md  "$pkgdir/usr/share/doc/$pkgname/CHANGES.md"
}
